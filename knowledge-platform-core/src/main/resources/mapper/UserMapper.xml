<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.knowledge.core.mapper.UserMapper">

    <select id="selectByUsername" resultType="com.knowledge.core.entity.UserEntity">
        SELECT * FROM user WHERE username = #{username} AND status = 1
    </select>

    <select id="selectByEmail" resultType="com.knowledge.core.entity.UserEntity">
        SELECT * FROM user WHERE email = #{email} AND status = 1
    </select>
</mapper>